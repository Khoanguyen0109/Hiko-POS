{
  "name": "pos-backend",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "start:migrate": "node scripts/start-with-migrate.js",
    "migrate": "node seeds/migrateToMultiStore.js",
    "migrate:dry": "node seeds/migrateToMultiStore.js --dry-run",
    "migrate:rollback": "node seeds/rollbackMultiStore.js",
    "build": "echo 'No build step required for Node.js backend'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=orderController|promotionService",
    "test:integration": "jest --testPathPatterns=integration",
    "test:runner": "node test-runner.js",
    "test:orders": "node manual-test-orders.js",
    "test:orders:full": "node tests/order-promotion-tests.js"
  },
  "keywords": [
    "pos",
    "restaurant",
    "backend",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Restaurant POS System Backend API",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.2.1",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.4"
  }
}
