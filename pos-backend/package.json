{
  "name": "pos-backend",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch app.ts",
    "start": "node dist/app.js",
    "start:migrate": "node dist/scripts/start-with-migrate.js",
    "migrate": "tsx seeds/migrateToMultiStore.ts",
    "migrate:dry": "tsx seeds/migrateToMultiStore.ts --dry-run",
    "migrate:rollback": "tsx seeds/rollbackMultiStore.ts",
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=orderController|promotionService",
    "test:integration": "jest --testPathPatterns=integration",
    "test:runner": "tsx test-runner.ts",
    "test:orders": "tsx manual-test-orders.ts",
    "test:orders:full": "tsx tests/order-promotion-tests.ts"
  },
  "keywords": [
    "pos",
    "restaurant",
    "backend",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "description": "Restaurant POS System Backend API",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.2.1",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}