{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "types": ["node", "jest"]
  },
  "include": ["./**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "api-test.ts",
    "manual-test-orders.ts",
    "test-runner.ts",
    "test-week50-api.ts",
    "test-schedule-api.ts",
    "create-week50-schedules.ts",
    "tests/order-promotion-tests.ts"
  ]
}
